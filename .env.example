# AdGenAI — copy to .env.local

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AdGenAI

# Neon Postgres (optional for local — falls back to in-memory)
# Required on Vercel for multi-user sessions / users / Stripe
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ─── AI (server defaults; users can also BYOK in Settings) ───
# Free-tier default provider is Groq
GROQ_API_KEY=
# Optional free/default cloud
XAI_API_KEY=
XAI_MODEL=grok-4
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── GitHub one-click push (REQUIRED for end users) ───
# Create OAuth App: https://github.com/settings/developers → New OAuth App
#   Homepage:           {NEXT_PUBLIC_APP_URL}
#   Callback URL:       {NEXT_PUBLIC_APP_URL}/api/github/callback
#   e.g. local:         http://localhost:3001/api/github/callback
# Users only click "Push" → authorize → repo is created automatically.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Encrypts token cookie (defaults to GITHUB_CLIENT_SECRET if unset)
GITHUB_TOKEN_SECRET=
# Dev fallback only (hidden when OAuth is configured): classic PAT with repo scope

# ─── Stripe Pro ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=price_...
# Promo codes that unlock Pro (comma-separated). Also includes built-ins:
# ADGEN-FOUNDER, NORTH-PRO, KEEP-BUILDING, ADGEN_SAAS_PRO
PROMO_CODES=ADGEN-FOUNDER,NORTH-PRO

# Deploy (optional)
VERCEL_TOKEN=
