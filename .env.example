# AdGenAI — copy to .env.local

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AdGenAI

# Neon Postgres (optional for local — falls back to in-memory)
# Required on Vercel for multi-user sessions / users / Stripe
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ─── AI (server defaults; users can also BYOK in Settings) ───
# Free-tier default provider is Groq
GROQ_API_KEY=
# Optional free/default cloud
XAI_API_KEY=
XAI_MODEL=grok-4
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── GitHub (Sign in + push full Vite projects) ───
# Option A — OAuth app: https://github.com/settings/developers
#   Authorization callback URL: {NEXT_PUBLIC_APP_URL}/api/github/callback
#   e.g. http://localhost:3001/api/github/callback  (match your dev port)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Encrypts token cookie (defaults to GITHUB_CLIENT_SECRET if unset)
GITHUB_TOKEN_SECRET=
# Option B — no OAuth app: users paste a classic PAT (repo scope) in the Push dialog
#   https://github.com/settings/tokens/new?scopes=repo

# ─── Stripe Pro ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=price_...
# Optional founder promo codes (comma-separated)
PROMO_CODES=ADGEN-FOUNDER

# Deploy (optional)
VERCEL_TOKEN=
