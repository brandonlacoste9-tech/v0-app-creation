# Shipboard Ã¢â‚¬â€ copy to .env.local

# App
NEXT_PUBLIC_APP_URL=https://www.shipboard.ca
NEXT_PUBLIC_APP_NAME=Shipboard

# Neon Postgres (optional for local Ã¢â‚¬â€ falls back to in-memory)
# Required on Vercel for multi-user sessions / users / Stripe
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ AI (server defaults; users can also BYOK in Settings) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
# Free-tier default provider is Groq
GROQ_API_KEY=
# Optional free/default cloud
XAI_API_KEY=
XAI_MODEL=grok-4
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ GitHub one-click push (REQUIRED for end users) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
# Create OAuth App: https://github.com/settings/developers Ã¢â€ â€™ New OAuth App
#   Homepage:           {NEXT_PUBLIC_APP_URL}
#   Callback URL:       {NEXT_PUBLIC_APP_URL}/api/github/callback
#   e.g. local:         http://localhost:3001/api/github/callback
# Users only click "Push" Ã¢â€ â€™ authorize Ã¢â€ â€™ repo is created automatically.
# Callback URL in GitHub OAuth App MUST be exactly:
#   {NEXT_PUBLIC_APP_URL}/api/github/callback
# Optional: GITHUB_REDIRECT_URI=https://www.shipboard.ca/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Encrypts token cookie (defaults to GITHUB_CLIENT_SECRET if unset)
GITHUB_TOKEN_SECRET=
# Dev fallback only (hidden when OAuth is configured): classic PAT with repo scope

# Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ Stripe Pro Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs: Builder $15 / Pro $25 / Max $45 CAD monthly
STRIPE_PRICE_ID_BUILDER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_MAX=price_...
# Legacy alias (Builder fallback + health)
STRIPE_PRICE_ID=price_...
# Optional Payment Link fallbacks
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_MONTHLY=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_ANNUAL=https://buy.stripe.com/...
# Webhook: https://YOUR-NETLIFY-URL/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted

# Promo codes that unlock Pro (comma-separated). Also includes built-ins:
# ADGEN-FOUNDER, NORTH-PRO, KEEP-BUILDING, ADGEN_SAAS_PRO
PROMO_CODES=ADGEN-FOUNDER,NORTH-PRO

# Deploy (optional)
VERCEL_TOKEN=


# --- Google Sign-in (optional) ---
# Google Cloud Console â†’ APIs & Services â†’ Credentials â†’ OAuth 2.0 Client (Web)
#   Authorized JavaScript origins:  https://www.shipboard.ca
#   Authorized redirect URIs:       https://www.shipboard.ca/api/google/callback
# Must match NEXT_PUBLIC_APP_URL host exactly (www vs apex).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional full override:
# GOOGLE_REDIRECT_URI=https://www.shipboard.ca/api/google/callback

